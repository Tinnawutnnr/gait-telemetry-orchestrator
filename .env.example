# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=gait

# App — must match the Postgres values above
DATABASE_URL=

#AUTH Config.py
SECRET_KEY=
HASH_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAXMEMORY=256mb

# HiveMQ broker credentials
MQTT_BROKER=your-cluster.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USE_TLS=true
MQTT_QOS=1

# Stream tuning
STREAM_MAXLEN=1000